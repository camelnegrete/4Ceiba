    {
      "name": "Citas",
      "item": [
        {
          "name": "Reservar cita",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('201 Created', () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('appointmentId', body.id);",
              "pm.test('estado PROGRAMADA', () => pm.expect(body.status).to.eql('PROGRAMADA'));"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/v1/appointments", "host": ["{{baseUrl}}"], "path": ["api","v1","appointments"] },
            "body": { "mode": "raw", "raw": "{\n  \"doctorId\": \"{{doctorId}}\",\n  \"patientId\": \"{{patientId}}\",\n  \"appointmentDateTime\": \"{{appointmentDateTime}}\"\n}" }
          }
        },
        {
          "name": "Consultar disponibilidad",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/appointments/available-slots?doctorId={{doctorId}}&startDate={{slotDate}}&endDate={{slotDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","appointments","available-slots"],
              "query": [
                { "key": "doctorId", "value": "{{doctorId}}" },
                { "key": "startDate", "value": "{{slotDate}}" },
                { "key": "endDate", "value": "{{slotDate}}" }
              ]
            }
          }
        },
        {
          "name": "Listar citas (filtros + paginación)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/appointments?doctorId={{doctorId}}&status=PROGRAMADA&page=0&size=20&sort=appointmentDateTime,asc",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","appointments"],
              "query": [
                { "key": "doctorId", "value": "{{doctorId}}" },
                { "key": "patientId", "value": "{{patientId}}", "disabled": true },
                { "key": "status", "value": "PROGRAMADA" },
                { "key": "from", "value": "2026-01-01T00:00:00Z", "disabled": true },
                { "key": "to", "value": "2027-01-01T00:00:00Z", "disabled": true },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "sort", "value": "appointmentDateTime,asc" }
              ]
            }
          }
        },
        {
          "name": "Reprogramar cita",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.collectionVariables.set('appointmentId', pm.response.json().id);"
            ] } }
          ],
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/v1/appointments/{{appointmentId}}/schedule", "host": ["{{baseUrl}}"], "path": ["api","v1","appointments","{{appointmentId}}","schedule"] },
            "body": { "mode": "raw", "raw": "{\n  \"newAppointmentDateTime\": \"{{rescheduleDateTime}}\"\n}" }
